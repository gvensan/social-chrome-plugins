{
  "manifest_version": 3,
  "name": "Hugging Face Search Toolkit (Unofficial)",
  "version": "0.1.0",
  "description": "Unofficial. Compose Hugging Face Models / Datasets / Spaces search URLs with task, library, license filters.",
  "action": {
    "default_title": "Hugging Face Search Toolkit (Unofficial)",
    "default_popup": "src/popup/index.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "background": {
    "service_worker": "src/background/service-worker.ts",
    "type": "module"
  },
  "side_panel": {
    "default_path": "src/popup/index.html"
  },
  "permissions": ["storage", "sidePanel"],
  "minimum_chrome_version": "114"
}
